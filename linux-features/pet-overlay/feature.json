{
  "id": "pet-overlay",
  "title": "Pet Overlay",
  "description": "Optional Linux avatar overlay placement and compositor hints.",
  "defaultEnabled": false,
  "entrypoints": {
    "patchDescriptors": "./patch.js"
  },
  "runtimeHooks": {
    "env": {
      "source": "gpu-compositing.env",
      "name": "gpu-compositing.env",
      "mode": "0644"
    }
  },
  "petOverlay": {
    "gravity": "bottom-right",
    "margin": 24,
    "allWorkspaces": true,
    "alwaysOnTop": true,
    "skipTaskbar": true,
    "lockPosition": false,
    "mode": "interactive",
    "hyprland": true
  }
}
